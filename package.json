{
  "name": "cleanclaw",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace web",
    "dev:desktop": "npm run dev --workspace desktop",
